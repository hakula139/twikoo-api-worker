{
  "name": "twikoo-api-worker",
  "description": "Cloudflare Workers backend for the Twikoo comment system, backed by D1 and R2.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/worker.ts",
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "check": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "deploy": "wrangler deploy --minify",
    "dev": "wrangler dev",
    "format": "prettier --check .",
    "lint": "pnpm lint:md && pnpm lint:js",
    "lint:js": "eslint .",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "postinstall": "node scripts/bundle-trim.mjs",
    "spellcheck": "cspell --no-progress \"**/*\""
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.7.3",
    "twikoo-func": "^1.7.9",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260507.1",
    "@types/node": "^25.6.0",
    "cspell": "^10.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "wrangler": "^4.88.0"
  }
}
